# Server
SIGNAL_ADDR=:8080
SIGNAL_ALLOWED_ORIGINS=
SIGNAL_READ_TIMEOUT=10
SIGNAL_WRITE_TIMEOUT=10
SIGNAL_MAX_MSG_BYTES=65536
SIGNAL_WS_PING_INTERVAL=10
SIGNAL_WS_PONG_WAIT=25

# Security
SIGNAL_JWT_SECRET=change-me
SIGNAL_ADMIN_KEY=
SIGNAL_WS_RPS=20
SIGNAL_WS_BURST=40

# Redis (optional for multi-node)
SIGNAL_REDIS_ENABLED=false
SIGNAL_REDIS_ADDR=localhost:6379
SIGNAL_REDIS_DB=0
SIGNAL_REDIS_PASSWORD=

# STUN/TURN
SIGNAL_STUN=stun:stun.l.google.com:19302
# Example TURN
# SIGNAL_TURN_URLS=turn:turn.example.com:3478
# SIGNAL_TURN_USERNAME=username
# SIGNAL_TURN_CREDENTIAL=password
# SIGNAL_TURN_TTL=600

# Observability
SIGNAL_PROM_ENABLED=true
SIGNAL_METRICS_ADDR=:9090
